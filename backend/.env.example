# Backend WSDC Environment
ENVIRONMENT=development
WSDC_API_KEY="your-api-key-here"

# Database (Supabase — use asyncpg driver, URL-encode special chars in password)
DATABASE_URL="postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?ssl=require"

# Redis (Upstash — must use rediss:// for TLS)
REDIS_URL="rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379?ssl_cert_reqs=none"

# Gemini AI (Google AI Studio)
GEMINI_API_KEY="your-gemini-api-key"

# GitHub App (from Probot setup)
APP_ID="your-app-id"
WEBHOOK_SECRET="your-webhook-secret"
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
